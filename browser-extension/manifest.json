{
  "manifest_version": 3,
  "name": "Content Agent Inbox Capture",
  "version": "0.1.0",
  "description": "Capture current page into local inbox server.",
  "permissions": ["storage", "tabs", "activeTab"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*"],
  "action": {
    "default_title": "Capture to Inbox",
    "default_popup": "popup.html"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y"
      }
    }
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "options_page": "options.html"
}
